{
  "name": "ygo-card-checker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "db:sync": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/sync.ts",
    "db:sync:full": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/sync.ts --it",
    "db:tag": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/tag.ts",
    "db:parse-effects": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/parse-effects.ts",
    "db:relations": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/build-relations.ts",
    "db:format-legality": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/build-format-legality.ts",
    "db:export:formats": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/export-format-legality.ts",
    "db:export": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/export.ts",
    "db:combos": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/build-combos.ts",
    "db:test:effects": "node --import tsx tools/card-knowledge-db/src/effect-parser.test.ts",
    "db:stats": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/stats.ts",
    "db:query": "node --experimental-sqlite --import tsx tools/card-knowledge-db/src/query-card.ts",
    "db:build": "npm run db:sync && npm run db:parse-effects && npm run db:tag && npm run db:format-legality && npm run db:relations && npm run db:export && npm run db:export:formats && npm run db:combos"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.31",
    "@angular/cli": "^20.3.31",
    "@angular/compiler-cli": "^20.3.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/jasmine": "~5.1.0",
    "daisyui": "^5.6.10",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  }
}
