# Copia in .env.local e compila con i valori dal dashboard Supabase.
# Nomi accettati (il primo trovato vince):
#   URL:  SUPABASE_URL | NG_APP_SUPABASE_URL | NEXT_PUBLIC_SUPABASE_URL
#   Key:  SUPABASE_ANON_KEY | SUPABASE_PUBLISHABLE_KEY | NG_APP_SUPABASE_ANON_KEY
#         | NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY | NEXT_PUBLIC_SUPABASE_ANON_KEY

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# OAuth setup (scripts/configure-supabase-oauth.mjs)
# SUPABASE_ACCESS_TOKEN=sbp_...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# DISCORD_CLIENT_ID=...
# DISCORD_CLIENT_SECRET=...
